# Google Gemini API Key - get free at aistudio.google.com
GOOGLE_API_KEY=your_gemini_api_key_here

# Telegram Bot Token - get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional - for baseline comparison systems
URLSCAN_API_KEY=your_urlscan_key_here
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# Set to true for production deployment (no query content stored)
ZERO_RETENTION_MODE=false

# Backend API server settings (used by frontend and Postman)
NOVAGUARD_API_URL=http://localhost:8000
# Optional - if set, every request must include X-API-Key: <this value>
NOVAGUARD_API_KEY=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: groq | sambanova | gemini
# Vision (screenshot OCR) always uses Gemini regardless of this setting.

# Option 1 — NVIDIA NIM (recommended; generous free credits, DeepSeek-V4-Pro)
# Sign up at https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
LLM_PROVIDER=nvidia
# NVIDIA models: deepseek-ai/deepseek-v4-pro | deepseek-ai/deepseek-v4-flash
LLM_MODEL=deepseek-ai/deepseek-v4-pro

# Option 2 — Groq Cloud (free tier, fast Llama models)
# Sign up at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
# To use Groq: set LLM_PROVIDER=groq and LLM_MODEL=llama-3.3-70b-versatile

# Option 3 — SambaNova Cloud
# Sign up at https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=your_sambanova_key_here
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
# To use SambaNova: set LLM_PROVIDER=sambanova and LLM_MODEL=Meta-Llama-3.3-70B-Instruct

# Option 4 — Google Gemini (already configured above via GOOGLE_API_KEY)
# To use Gemini for the agent too: set LLM_PROVIDER=gemini and LLM_MODEL=gemini-2.0-flash
