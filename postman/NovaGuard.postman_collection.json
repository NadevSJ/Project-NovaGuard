{
  "info": {
    "name": "NovaGuard API",
    "_postman_id": "novaguard-v1-collection",
    "description": "REST API for the NovaGuard scam-detection agent. All endpoints are under /api/v1. Set the `base_url` and (if your backend requires it) `api_key` collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "X-API-Key", "type": "string" },
      { "key": "value", "value": "{{api_key}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "api_key", "value": "", "type": "string" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is JSON', function () {",
          "  pm.response.to.have.header('Content-Type');",
          "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});",
          "pm.test('Status < 500', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Meta",
      "item": [
        {
          "name": "GET /api/v1/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "health"]
            },
            "description": "Liveness + dependency check. Returns `status: ok` if GOOGLE_API_KEY is set."
          }
        },
        {
          "name": "GET /api/v1/version",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/version",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "version"]
            },
            "description": "Backend version, current Gemini model, and which optional services are configured."
          }
        },
        {
          "name": "POST /api/v1/warmup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/warmup",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "warmup"]
            },
            "description": "Eagerly initialise the agent and vision inspector so the first user request is fast."
          }
        }
      ]
    },
    {
      "name": "Investigate",
      "item": [
        {
          "name": "POST /api/v1/investigate — SCAM SMS example",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"URGENT: Your BOC account suspended. Verify PIN: http://boc-verify.xyz\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/investigate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "investigate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Predicted label is set', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.predicted_label).to.be.oneOf(['SCAM','SUSPICIOUS','LIKELY_SAFE','SAFE']);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/investigate — URL example",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"https://suspicious-bank-login.example/secure\",\n  \"input_type_hint\": \"url\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/investigate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "investigate"]
            }
          }
        },
        {
          "name": "POST /api/v1/investigate — Legitimate SMS",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"Your Sampath Bank transaction of Rs.2,500 on 15/01/2025. Ref: TXN789456. Hotline: 0112-303030\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/investigate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "investigate"]
            }
          }
        },
        {
          "name": "POST /api/v1/investigate/email — phishing email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sender\": \"boc-support@secure-banking-alert.com\",\n  \"subject\": \"URGENT - Your BOC Internet Banking Account Suspended\",\n  \"body\": \"Dear Customer, Your BOC account has been temporarily suspended due to suspicious activity. Click here to verify: http://boc-verify-now.xyz/login\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/investigate/email",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "investigate", "email"]
            }
          }
        },
        {
          "name": "POST /api/v1/investigate/screenshot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "PNG / JPEG / WEBP screenshot of the suspicious message"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/investigate/screenshot",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "investigate", "screenshot"]
            },
            "description": "Multipart upload — attach an image to the `file` form field in Postman."
          }
        }
      ]
    },
    {
      "name": "Feedback",
      "item": [
        {
          "name": "POST /api/v1/feedback — confirm correct verdict",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"URGENT: Your BOC account suspended. Verify PIN: http://boc-verify.xyz\",\n  \"predicted_label\": \"SCAM\",\n  \"feedback_type\": \"correct\",\n  \"input_type\": \"text\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/feedback",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feedback"]
            }
          }
        },
        {
          "name": "POST /api/v1/feedback — correction (false negative)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"input\": \"Win Rs.50,000 in our lucky draw — claim at http://win-now.xyz\",\n  \"predicted_label\": \"LIKELY_SAFE\",\n  \"feedback_type\": \"incorrect\",\n  \"correct_label\": \"SCAM\",\n  \"input_type\": \"text\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/feedback",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feedback"]
            }
          }
        },
        {
          "name": "GET /api/v1/feedback/stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/feedback/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feedback", "stats"]
            }
          }
        },
        {
          "name": "POST /api/v1/feedback/export",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_path\": \"evaluation/dataset/feedback_dataset.json\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/feedback/export",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "feedback", "export"]
            }
          }
        }
      ]
    }
  ]
}
